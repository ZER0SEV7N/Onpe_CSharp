@{
    ViewData["Title"] = "Actas por Ubigeo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <section class="contenedor">
        <div class="row">
            <div class="col-xs-12 col-md-3">
                <!-- menu Interno -->
                <div class="menu-interna">
                    <ul>
                        <li><a href="@Url.Action("Ubigeo", "Acta")" class="act-izq act-amarillo">Por Ubigeo</a></li>
                        <li><a href="@Url.Action("Numero", "Acta")" class="act-izq">Por número</a></li>
                    </ul>
                </div>
            </div>
            <div class="col-xs-12 col-md-9" id="impreso">
                <div class="contenido-interna">
                    <div class="titulos col-xs-12">
                        <div class="col-xs-11">
                            <h3> <span class="glyphicon glyphicon-circle-arrow-right" aria-hidden="true" style="font-size:19px"></span> SEGUNDA ELECCIÓN PRESIDENCIAL 2016: RESULTADOS DE ACTAS</h3>
                        </div>
                    </div>
                    <!-- Filtro de Búsqueda -->
                    <div class="col-xs-12">
                        <p class="subtitle">BÚSQUEDA DE ACTAS POR UBIGEO</p>
                        <br/>
                        
                        <div class="row pbot20">
                            <div class="col-md-3 col-sm-4 form-group">
                                <label class="control-label">Ámbito:</label>
                                <select id="cboAmbito" class="form-control">
                                    <option value="Nacional" selected>PERÚ</option>
                                    <option value="Extranjero">EXTRANJERO</option>
                                </select>
                            </div>
                            <div class="col-md-4 col-sm-4 form-group">
                                <label id="lblDepartamento" class="control-label">Departamento:</label>
                                <select id="cboDepartamento" class="form-control">
                                    <option value="">-- SELECCIONE --</option>
                                </select>
                            </div>
                            <div class="col-md-5 col-sm-4 form-group">
                                <label id="lblProvincia" class="control-label">Provincia:</label>
                                <select id="cboProvincia" class="form-control">
                                    <option value="">-- SELECCIONE --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row pbot30">
                            <div class="col-md-4 col-sm-4 form-group">
                                <label id="lblDistrito" class="control-label">Distrito:</label>
                                <select id="cboDistrito" class="form-control">
                                    <option value="">-- SELECCIONE --</option>
                                </select>
                            </div>
                            <div class="col-md-8 col-sm-8 form-group">
                                <label class="control-label">Locales:</label>
                                <select id="cboLocal" class="form-control">
                                    <option value="">-- SELECCIONE --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <!-- Contenedor de Mesas -->
                    <div id="contenedorMesas" class="col-xs-12 ptop20" style="display:none;">
                        <div style="background-color: #c89f3b; color: white; padding: 5px 10px; font-weight: bold;">LISTADO DE MESAS</div>
                        
                        <div id="grillaMesas" class="row" style="background-color: #d9d9d9; margin: 0; padding: 15px;">
                            </div>

                        <div class="row ptop20">
                            <div class="col-md-12 text-center" style="border: 1px solid #ccc; padding: 10px; display: flex; justify-content: space-around;">
                                <span><div style="width:15px;height:15px;background:#98b1e4;display:inline-block;vertical-align:middle;margin-right:5px;"></div> Procesada con imagen</span>
                                <span><div style="width:15px;height:15px;background:#b3b3b3;display:inline-block;vertical-align:middle;margin-right:5px;"></div> Procesada sin imagen</span>
                                <span><div style="width:15px;height:15px;background:#e5cda1;display:inline-block;vertical-align:middle;margin-right:5px;"></div> Sin procesar</span>
                            </div>
                        </div>
                    </div>
                    <!-- Contenedor de Acta Detalle -->
                    <div id="contenedorActaDetalle" class="col-xs-12 ptop20" style="display:none;">
                        <div class="text-right pbot10">
                            <button id="btnRegresarMesas" type="button" class="btn btn-primary" style="background-color: #337ab7; border-color: #2e6da4;">
                                <span class="glyphicon glyphicon-chevron-left"></span> REGRESAR
                            </button>
                        </div>
                        <div id="htmlActa"></div> 
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const UrlsActa = {
            departamentos: '@Url.Action("CargarDepartamentos", "Acta")',
            provincias: '@Url.Action("CargarProvincias", "Acta")',
            distritos: '@Url.Action("CargarDistritos", "Acta")',
            locales: '@Url.Action("CargarLocales", "Acta")',
            mesas: '@Url.Action("CargarMesas", "Acta")',
            detalle: '@Url.Action("ObtenerDetalle", "Acta")'
        };
    </script>
    
    <script src="~/js/comboBox.js"></script>
}